<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] Degra 2.0</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <script>
        tailwind.config = {
            darkMode: 'class'
        }
        
        const savedTheme = localStorage.getItem('theme') || 'light';
        if (savedTheme === 'dark') {
            document.documentElement.classList.add('dark');
        } else {
            document.documentElement.classList.remove('dark');
        }
    </script>
    <style>
        :root {
            --background: #F9F9F9;
            --foreground: #1a1a1a;
            --card: #ffffff;
            --border: rgba(0, 0, 0, 0.08);
            --primary: #2563EB;
            --primary-foreground: #ffffff;
            --sidebar: #ffffff;
            --sidebar-accent: #f3f3f5;
            --header-bg: rgba(255, 255, 255, 0.8);
        }
        .dark {
            --background: #111111;
            --foreground: #F5F5F7;
            --card: #1C1C1E;
            --border: rgba(255, 255, 255, 0.1);
            --primary: #3B82F6;
            --primary-foreground: #ffffff;
            --sidebar: #1C1C1E;
            --sidebar-accent: #2C2C2E;
            --header-bg: rgba(28, 28, 30, 0.8);
        }
        body {
            background-color: var(--background);
            color: var(--foreground);
            font-family: 'Inter', sans-serif;
        }
        .bg-sidebar { background-color: var(--sidebar); }
        .border-border { border-color: var(--border); }
        .bg-card { background-color: var(--card); }
        .bg-primary-custom { background-color: var(--primary); color: var(--primary-foreground); }
        .bg-header { background-color: var(--header-bg); }
        .timetable-grid { display: grid; grid-template-columns: 100px repeat(5, 1fr); }
        .time-slot { height: 60px; border-bottom: 1px solid var(--border); }
        ::-webkit-scrollbar {
            width: 6px;
            height: 6px;
        }

        ::-webkit-scrollbar-track {
            background: transparent;
        }

        ::-webkit-scrollbar-thumb {
            background: var(--border);
            border-radius: 10px;
        }

        ::-webkit-scrollbar-thumb:hover {
            background: var(--sidebar-accent);
        }

        * {
            scrollbar-width: thin;
            scrollbar-color: var(--border) transparent;
        }
    </style>
</head>
<body class="h-screen overflow-hidden">
    <div class="flex h-full w-full">
        <aside class="w-64 bg-sidebar border-r border-border h-full flex flex-col backdrop-blur-sm">
            <div class="p-6 flex-1 flex flex-col overflow-hidden">
                <h2 class="mb-8 text-xl font-bold tracking-tight">System</h2>
                <nav class="space-y-2 mb-10">
                    <a asp-controller="Scheduler" asp-action="Index" class="w-full flex items-center gap-3 px-4 py-3 rounded-xl transition-all hover:bg-sidebar-accent/50">
                        <i data-lucide="calendar" class="w-5 h-5"></i>
                        <span>Timetable</span>
                    </a>
                    <a asp-controller="Rooms" asp-action="Index" class="w-full flex items-center gap-3 px-4 py-3 rounded-xl transition-all hover:bg-sidebar-accent/50">
                        <i data-lucide="download" class="w-5 h-5"></i>
                        <span>Rooms</span>
                    </a>
                    <a asp-controller="Teachers" asp-action="Index" class="w-full flex items-center gap-3 px-4 py-3 rounded-xl transition-all hover:bg-sidebar-accent/50">
                        <i data-lucide="users" class="w-5 h-5"></i>
                        <span>Teachers</span>
                    </a>
                    <a asp-controller="Scraper" asp-action="Index" class="w-full flex items-center gap-3 px-4 py-3 rounded-xl transition-all hover:bg-sidebar-accent/50">
                        <i data-lucide="refresh-cw" class="w-5 h-5"></i>
                        <span>Scraper</span>
                    </a>
                </nav>
                @RenderSection("SidebarExtra", required: false)
            </div>
            <div class="w-full flex items-center gap-3 px-4 py-4 border-t border-border mt-auto">
                <div class="w-9 h-9 rounded-full bg-gradient-to-br from-blue-500 to-purple-600 flex items-center justify-center text-white font-medium">WI</div>
                <div class="flex-1 text-left min-w-0">
                    <div class="font-medium text-sm truncate">PB User</div>
                    <div class="text-xs text-gray-500 truncate">Academic System</div>
                </div>
            </div>
        </aside>

        <main class="flex-1 flex flex-col overflow-hidden">
            <header class="border-b border-border px-8 py-5 flex items-center justify-between bg-header backdrop-blur-md sticky top-0 z-40">
                <div class="flex items-center gap-4">
                    @RenderSection("HeaderLeft", required: false)
                </div>
                <div class="flex items-center gap-3">
                    @RenderSection("HeaderRight", required: false)
                    <button onclick="toggleTheme()" class="p-2.5 hover:bg-sidebar-accent rounded-xl transition-colors">
                        <i id="theme-icon" data-lucide="moon" class="w-5 h-5"></i>
                    </button>
                </div>
            </header>

            <div id="main-content" class="flex-1 overflow-auto">
                @RenderBody()
            </div>
        </main>
    </div>

    <script>
        function updateThemeIcon() {
            const isDark = document.documentElement.classList.contains('dark');
            const icon = document.getElementById('theme-icon');
            if (icon) {
                icon.setAttribute('data-lucide', isDark ? 'sun' : 'moon');
                lucide.createIcons();
            }
        }

        function toggleTheme() {
            const html = document.documentElement;
            const isDarkNow = html.classList.toggle('dark');
            localStorage.setItem('theme', isDarkNow ? 'dark' : 'light');
            updateThemeIcon();
        }

        updateThemeIcon();
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>