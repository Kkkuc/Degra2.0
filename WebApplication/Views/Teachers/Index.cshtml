@model IEnumerable<WebApplication.Models.Teacher>

@section HeaderLeft {
    <div class="flex items-center gap-4">
        <h2 class="font-bold text-2xl tracking-tight">Teachers</h2>
    </div>
}

<div class="p-8">
    <div class="bg-card rounded-xl border border-border overflow-hidden">
        <table class="w-full text-left border-collapse">
            <thead>
                <tr class="border-b border-border bg-gray-50/50 dark:bg-gray-800/50">
                    <th class="px-6 py-4 font-semibold text-sm text-gray-500 uppercase">Teacher</th>
                    <th class="px-6 py-4 font-semibold text-sm text-gray-500 uppercase">Academic Title</th>
                    <th class="px-6 py-4 font-semibold text-sm text-gray-500 uppercase">Email Address</th>
                </tr>
            </thead>
            <tbody id="teachers-list" class="divide-y divide-border">
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        const STORAGE_KEY = 'teachers_cache';
        const TTL = 3600000;

        function initTeachers() {
            const serverData = @Html.Raw(Json.Serialize(Model));
            const cached = JSON.parse(localStorage.getItem(STORAGE_KEY));
            const now = Date.now();
            let teachers = [];

            if (serverData && serverData.length > 0) {
                teachers = serverData;
                localStorage.setItem(STORAGE_KEY, JSON.stringify({ data: serverData, timestamp: now }));
            } else if (cached && (now - cached.timestamp < TTL)) {
                teachers = cached.data;
            }

            renderTeachers(teachers);
        }

        function renderTeachers(teachers) {
            const list = document.getElementById('teachers-list');
            list.innerHTML = teachers.map(t => `
                <tr class="hover:bg-gray-50/50 dark:hover:bg-gray-800/50 transition-colors">
                    <td class="px-6 py-4">
                        <div class="flex items-center gap-3">
                            <div class="w-10 h-10 rounded-full bg-blue-100 dark:bg-blue-900/30 flex items-center justify-center text-blue-600 font-bold">
                                ${t.firstName[0]}${t.lastName[0]}
                            </div>
                            <div class="font-medium">${t.firstName} ${t.lastName}</div>
                        </div>
                    </td>
                    <td class="px-6 py-4 text-sm">
                        <span class="px-2.5 py-1 rounded-lg bg-gray-100 dark:bg-gray-800 font-medium">${t.academicTitle}</span>
                    </td>
                    <td class="px-6 py-4 text-sm text-gray-500">
                        <div class="flex items-center gap-2">
                            <i data-lucide="mail" class="w-4 h-4"></i>
                            ${t.email}
                        </div>
                    </td>
                </tr>
            `).join('');
            lucide.createIcons();
        }

        initTeachers();
    </script>
}