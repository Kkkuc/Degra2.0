@model IEnumerable<WebApplication.Models.Teacher>

@{
    ViewData["Title"] = "Teachers List";
}

<div class="container mt-4">
    <h2>University Teachers</h2>
    <p>Total records: @Model.Count()</p>

    <table class="table table-striped table-hover mt-3">
        <thead class="table-dark">
            <tr>
                <th>Title</th>
                <th>First Name</th>
                <th>Last Name</th>
                <th>Email</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var teacher in Model)
            {
                <tr>
                    <td>@teacher.AcademicTitle</td>
                    <td>@teacher.FirstName</td>
                    <td>@teacher.LastName</td>
                    <td>@(teacher.Email ?? "Not provided")</td>
                </tr>
            }
        </tbody>
    </table>
</div>