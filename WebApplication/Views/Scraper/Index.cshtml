@{
    ViewData["Title"] = "Scraper Dashboard";
}

<div class="text-center mt-5">
    <h1 class="display-4">Scraper Dashboard</h1>
    <p class="lead">Use this panel to pull the latest timetable data from the university website.</p>

    <!-- Display the success message if it exists -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card mt-4 mx-auto" style="max-width: 500px;">
        <div class="card-body">
            <h5 class="card-title">Database Status</h5>
            <ul class="list-group list-group-flush mb-4 text-start">
                <li class="list-group-item">Teachers in Database: <strong>@ViewBag.TeacherCount</strong></li>
                <li class="list-group-item">Timetable Entries: <strong>@ViewBag.TimetableCount</strong></li>
            </ul>

            <!-- The Form that triggers the scraper -->
            <form asp-controller="Scraper" asp-action="RunScraper" method="post">
                <button type="submit" class="btn btn-primary btn-lg" onclick="this.innerHTML='Scraping... Please wait.'; this.classList.add('disabled');">
                    Start Scraping Now
                </button>
            </form>
            
            <div class="mt-3 text-muted small">
                <i class="bi bi-info-circle"></i> Note: Scraping 150+ teachers takes about 1-2 minutes. Do not close the page while it is loading.
            </div>
        </div>
    </div>
</div>